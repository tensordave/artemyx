---
import { examples, groups, type Example } from '../scripts/examples/registry';
import Header from './Header.astro';
import 'maplibre-gl/dist/maplibre-gl.css';
import '../styles/global.css';

interface Props {
	activeExample: Example;
	highlightedYaml: string;
}

const { activeExample, highlightedYaml } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>artemyx — {activeExample.name}</title>
	</head>
	<body class="examples">
		<Header />

		<div class="examples-layout">
			<aside class="examples-sidebar" id="examples-sidebar">
				<button class="examples-sidebar-close" id="sidebar-close" aria-label="Close examples menu">&times;</button>
				{groups.map(group => (
					<div class="examples-sidebar-group">
						<div class="examples-sidebar-group-title">{group}</div>
						<ul class="examples-sidebar-list">
							{examples.filter(e => e.group === group).map(example => (
								<li>
									<a
										href={example.slug === examples[0].slug ? '/examples' : `/examples/${example.slug}`}
										class:list={['examples-sidebar-item', { 'examples-sidebar-item--active': example.slug === activeExample.slug }]}
									>
										<span class="examples-sidebar-name">{example.name}</span>
										<span class="examples-sidebar-desc">{example.description}</span>
									</a>
								</li>
							))}
						</ul>
					</div>
				))}
				<div class="examples-sidebar-nav">
					<a href="/#about" class="examples-sidebar-nav-link">About</a>
					<a href="/app" class="examples-sidebar-nav-link">App</a>
					<a href="https://github.com/tensordave/artemyx" class="examples-sidebar-nav-link">GitHub</a>
				</div>
			</aside>

			<main class="examples-main">
				<div id="map" data-config={activeExample.configPath} data-persistence="false"></div>
				<button class="examples-config-btn" id="config-toggle">View config</button>
				<div class="examples-sheet" id="config-sheet">
					<div class="examples-sheet-header">
						<span>{activeExample.configPath.split('/').pop()}</span>
						<button class="examples-sheet-close" id="config-close">&times;</button>
					</div>
					<div class="examples-sheet-body" set:html={highlightedYaml} />
				</div>
			</main>
		</div>

		<script>
			import '../scripts/map.ts';
		</script>
		<script>
			// Bottom sheet toggle
			const toggleBtn = document.getElementById('config-toggle');
			const closeBtn = document.getElementById('config-close');
			const sheet = document.getElementById('config-sheet');

			if (toggleBtn && sheet) {
				toggleBtn.addEventListener('click', () => {
					sheet.classList.toggle('examples-sheet--open');
				});
			}

			if (closeBtn && sheet) {
				closeBtn.addEventListener('click', () => {
					sheet.classList.remove('examples-sheet--open');
				});
			}

			// Mobile sidebar toggle
			const hamburger = document.getElementById('header-hamburger');
			const sidebar = document.getElementById('examples-sidebar');

			const sidebarClose = document.getElementById('sidebar-close');

			if (hamburger && sidebar) {
				hamburger.addEventListener('click', () => {
					sidebar.classList.toggle('examples-sidebar--open');
				});

				// Close sidebar when clicking a link
				sidebar.querySelectorAll('.examples-sidebar-item, .examples-sidebar-nav-link').forEach(link => {
					link.addEventListener('click', () => {
						sidebar.classList.remove('examples-sidebar--open');
					});
				});
			}

			if (sidebarClose && sidebar) {
				sidebarClose.addEventListener('click', () => {
					sidebar.classList.remove('examples-sidebar--open');
				});
			}
		</script>
	</body>
</html>
