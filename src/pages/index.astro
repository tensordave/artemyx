---
import Header from '../components/Header.astro';
import { highlightConfigYaml } from '../utils/highlight-config';
import 'maplibre-gl/dist/maplibre-gl.css';
import '../styles/global.css';
import { cloudArrowDownIcon, codeBlockIcon, stackIcon, databaseIcon, mapTrifoldIcon, circleIcon } from '../scripts/icons';

const configFile = 'demo-config.yaml';
const highlightedYaml = await highlightConfigYaml(configFile);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>artemyx</title>
	</head>
	<body class="landing">
		<Header />
		<aside class="header-sidebar" id="header-sidebar">
			<button class="header-sidebar-close" id="header-sidebar-close" aria-label="Close menu">&times;</button>
			<a href="#about" class="header-sidebar-link">About</a>
			<a href="/app" class="header-sidebar-link">App</a>
			<a href="/examples" class="header-sidebar-link">Examples</a>
			<a href="https://github.com/tensordave/artemyx" class="header-sidebar-link">GitHub</a>
		</aside>

		<!-- Live demo -->
		<section class="demo-section">
			<div id="map" data-config="/demo-config.yaml" data-persistence="false"></div>
			<div id="config-highlighted" data-config-filename={configFile} hidden set:html={highlightedYaml} />
			<p class="demo-caption">
				Vancouver bikeways colored by distance to the nearest rapid transit station.
				Green = close, amber = moderate, red = far.
			</p>
		</section>

		<!-- Controls guide -->
		<section class="about-section" id="using">
			<h2 class="section-heading">Using the app</h2>
			<div class="features-grid controls-grid">
				<div class="feature-card">
					<div class="control-card-icon" set:html={cloudArrowDownIcon} />
					<div class="feature-card-title">Load data</div>
					<p class="feature-card-body">Paste any GeoJSON, CSV, or GeoParquet URL to add a layer to the map.</p>
				</div>
				<div class="feature-card">
					<div class="control-card-icon" set:html={codeBlockIcon} />
					<div class="feature-card-title">View config</div>
					<p class="feature-card-body">Opens a panel showing the active YAML configuration with syntax highlighting.</p>
				</div>
				<div class="feature-card">
					<div class="control-card-icon" set:html={stackIcon} />
					<div class="feature-card-title">Layers</div>
					<p class="feature-card-body">Toggle layer visibility, change colors, rename, or delete datasets.</p>
				</div>
				<div class="feature-card">
					<div class="control-card-icon" set:html={databaseIcon} />
					<div class="feature-card-title">Storage</div>
					<p class="feature-card-body">Session persistence status - datasets survive page refresh via browser storage.</p>
				</div>
				<div class="feature-card">
					<div class="control-card-icon" set:html={mapTrifoldIcon} />
					<div class="feature-card-title">Basemap</div>
					<p class="feature-card-body">Switch between CARTO Dark and satellite basemaps.</p>
				</div>
				<div class="feature-card">
					<div class="control-card-icon" set:html={circleIcon} />
					<div class="feature-card-title">Status</div>
					<p class="feature-card-body">Shows loading and processing state; click to open the history log.</p>
				</div>
			</div>
		</section>

		<!-- About -->
		<section class="about-section" id="about">
			<h2 class="section-heading">How it works</h2>
			<div class="features-grid">
				<div class="feature-card">
					<div class="feature-card-title">Declarative YAML config</div>
					<p class="feature-card-body">
						Define datasets, spatial operations, and layer styles in one file.
						Point at any GeoJSON URL - municipal APIs, data portals, static files.
					</p>
				</div>
				<div class="feature-card">
					<div class="feature-card-title">Client-side spatial engine</div>
					<p class="feature-card-body">
						DuckDB-WASM runs full spatial SQL in the browser - buffer, intersect, union,
						difference, contains, distance, centroid - no server required.
					</p>
				</div>
				<div class="feature-card">
					<div class="feature-card-title">MapLibre GL expression support</div>
					<p class="feature-card-body">
						Write match and interpolate expressions directly in YAML to drive
						categorical and graduated styling from feature properties.
					</p>
				</div>
				<div class="feature-card">
					<div class="feature-card-title">Static-first, open source</div>
					<p class="feature-card-body">
						No backend, no accounts, no proprietary tiles. Runs entirely in the browser
						with free tile providers and publicly licensed data.
					</p>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="cta-section">
			<h2 class="cta-heading">Try it yourself</h2>
			<p class="cta-sub">Load the full app and paste in any GeoJSON URL to get started.</p>
			<a href="/app" class="cta-btn">Open the app</a>
		</section>

		<script>
			import '../scripts/map.ts';
		</script>
		<script>
			const hamburger = document.getElementById('header-hamburger');
			const sidebar = document.getElementById('header-sidebar');
			const sidebarClose = document.getElementById('header-sidebar-close');

			if (hamburger && sidebar) {
				hamburger.addEventListener('click', () => {
					sidebar.classList.toggle('header-sidebar--open');
				});

				sidebar.querySelectorAll('.header-sidebar-link').forEach(link => {
					link.addEventListener('click', () => {
						sidebar.classList.remove('header-sidebar--open');
					});
				});
			}

			if (sidebarClose && sidebar) {
				sidebarClose.addEventListener('click', () => {
					sidebar.classList.remove('header-sidebar--open');
				});
			}
		</script>
	</body>
</html>
