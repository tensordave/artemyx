---
import Header from '../components/Header.astro';
import 'maplibre-gl/dist/maplibre-gl.css';
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>artemyx</title>
	</head>
	<body class="landing">
		<Header />
		<aside class="header-sidebar" id="header-sidebar">
			<button class="header-sidebar-close" id="header-sidebar-close" aria-label="Close menu">&times;</button>
			<a href="#about" class="header-sidebar-link">About</a>
			<a href="/app" class="header-sidebar-link">App</a>
			<a href="/examples" class="header-sidebar-link">Examples</a>
			<a href="https://github.com/tensordave/artemyx" class="header-sidebar-link">GitHub</a>
		</aside>

		<!-- Hero -->
		<section class="hero">
			<h1 class="hero-title">Browser-based spatial analysis.</h1>
			<p class="hero-sub">
				Load GeoJSON, run spatial operations, style with MapLibre expressions —
				declared in YAML, computed in your browser.
			</p>
			<a href="/app" class="cta-btn">Open the app</a>
		</section>

		<!-- Live demo -->
		<section class="demo-section">
			<p class="demo-caption">
				Vancouver bikeways colored by distance to the nearest rapid transit station.
				Green = close, amber = moderate, red = far.
			</p>
			<div id="map" data-config="/demo-config.yaml" data-persistence="false"></div>
			<details class="demo-code-details">
				<summary class="demo-code-summary">View config</summary>
				<pre class="demo-code"><code># Two datasets from Vancouver Open Data

# Dataset definition:
datasets:
  - id: bikeways
    url: "https://opendata.vancouver.ca/..."
    name: Vancouver Bikeways
    color: "#22c55e"

  - id: rapidtransitstations
    url: "https://opendata.vancouver.ca/..."
    name: Rapid Transit Stations
    color: "#4ade80"

# Operation definition: in this example, annotate each bikeway with distance to nearest station
operations:
  - type: distance
    inputs: [bikeways, rapidtransitstations]
    output: bikeways_with_transit_dist
    params:
      mode: annotate
      units: km


# Layer definitions: interpolate expression colors bikeways by dist_km
layers:
  # bikeways line, shown under the bikeways layer with annotation
  - id: bikeways-line
    source: bikeways
    type: line
    paint:
      line-color:
        - interpolate
        - ["linear"]
        - ["coalesce", ["get", "speed_limit"], 0]
        - 0
        - "#94a3b8"
        - 30
        - "#22c55e"
        - 50
        - "#ef4444"
      line-width: 2.5

  # Bikeways colored green → amber → red by distance to transit (dist_km property)
  - id: bikeways-dist
    source: bikeways_with_transit_dist
    type: line
    paint:
      line-color:
        - interpolate
        - ["linear"]
        - ["get", "dist_km"]
        - 0
        - "#22c55e"   # green  — near transit
        - 0.5
        - "#eab308"   # amber  — moderate
        - 2
        - "#ef4444"   # red    — far from transit
      line-width: 3
	
  # Rapid transit stations as circles on top
  - id: transit-stations
    source: rapidtransitstations
    type: circle
    paint:
      circle-radius: 8
      circle-color: "#4ade80"
      circle-stroke-color: "#166534"
      circle-stroke-width: 2</code></pre>
			</details>
		</section>

		<!-- About -->
		<section class="about-section" id="about">
			<h2 class="section-heading">How it works</h2>
			<div class="features-grid">
				<div class="feature-card">
					<div class="feature-card-title">Declarative YAML config</div>
					<p class="feature-card-body">
						Define datasets, spatial operations, and layer styles in one file.
						Point at any GeoJSON URL — municipal APIs, data portals, static files.
					</p>
				</div>
				<div class="feature-card">
					<div class="feature-card-title">Client-side spatial engine</div>
					<p class="feature-card-body">
						DuckDB-WASM runs full spatial SQL in the browser — buffer, intersect, union,
						difference, contains, distance, centroid — no server required.
					</p>
				</div>
				<div class="feature-card">
					<div class="feature-card-title">MapLibre GL expression support</div>
					<p class="feature-card-body">
						Write match and interpolate expressions directly in YAML to drive
						categorical and graduated styling from feature properties.
					</p>
				</div>
				<div class="feature-card">
					<div class="feature-card-title">Static-first, open source</div>
					<p class="feature-card-body">
						No backend, no accounts, no proprietary tiles. Runs entirely in the browser
						with free tile providers and publicly licensed data.
					</p>
				</div>
			</div>
		</section>

		<!-- CTA -->
		<section class="cta-section">
			<h2 class="cta-heading">Try it yourself</h2>
			<p class="cta-sub">Load the full app and paste in any GeoJSON URL to get started.</p>
			<a href="/app" class="cta-btn">Open the app</a>
		</section>

		<script>
			import '../scripts/map.ts';
		</script>
		<script>
			const hamburger = document.getElementById('header-hamburger');
			const sidebar = document.getElementById('header-sidebar');
			const sidebarClose = document.getElementById('header-sidebar-close');

			if (hamburger && sidebar) {
				hamburger.addEventListener('click', () => {
					sidebar.classList.toggle('header-sidebar--open');
				});

				sidebar.querySelectorAll('.header-sidebar-link').forEach(link => {
					link.addEventListener('click', () => {
						sidebar.classList.remove('header-sidebar--open');
					});
				});
			}

			if (sidebarClose && sidebar) {
				sidebarClose.addEventListener('click', () => {
					sidebar.classList.remove('header-sidebar--open');
				});
			}
		</script>
	</body>
</html>
