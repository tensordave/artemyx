---
import ExampleLayout from '../../components/ExampleLayout.astro';
import { examples } from '../../scripts/examples/registry';

export function getStaticPaths() {
	return examples.map((example) => ({
		params: { slug: example.slug },
		props: { example },
	}));
}

const { example } = Astro.props;
---

<ExampleLayout activeExample={example} />
